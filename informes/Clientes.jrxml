	</subDataset>
	<queryString language="SQL">
		<![CDATA[SELECT usuario_login,
	correo,
	fecha_creacion
FROM servix.usuario
WHERE 
	 servix.usuario.rol = 'cliente' 
	 AND servix.usuario.fecha_creacion BETWEEN ' 2024-01-01' AND ' 2025-12-31']]>
	</queryString>
