	<parameter name="fechaActual" class="java.sql.Date">
		<defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT id_reserva,
	estado_reserva,
	fecha_hora,
	n_comensales,
	id_cliente
FROM servix.reserva
WHERE 
	 'fecha_hora' >= $P{fechaActual} 
	 AND servix.reserva.estado_reserva = 'cancelada' 
ORDER BY servix.reserva.fecha_hora ASC]]>
	</queryString>
